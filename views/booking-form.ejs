<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="results-header">
  <div class="results-header-inner">
    <a href="/offer/<%= offer.id %>" class="back-link">
      <i data-lucide="arrow-left" style="width:14px;height:14px;"></i>
      Back to offer
    </a>
    <div class="results-route">
      <div class="rr-airport">
        <div class="rr-iata"><%= offer.slices[0]?.origin %></div>
        <div class="rr-name"><%= origin_info ? origin_info.city : offer.slices[0]?.origin %></div>
      </div>
      <div class="rr-arrow">
        <% if (offer.slices.length > 1) { %>
          <i data-lucide="arrow-left-right" style="width:22px;height:22px;"></i>
        <% } else { %>
          <i data-lucide="arrow-right" style="width:22px;height:22px;"></i>
        <% } %>
      </div>
      <div class="rr-airport">
        <div class="rr-iata"><%= offer.slices[0]?.destination %></div>
        <div class="rr-name"><%= destination_info ? destination_info.city : offer.slices[0]?.destination %></div>
      </div>
    </div>
    <div class="results-meta">
      <span><i data-lucide="users" style="width:13px;height:13px;"></i> <%= offer.passenger_count %> passenger<%= offer.passenger_count > 1 ? 's' : '' %></span>
      <span><i data-lucide="lock" style="width:13px;height:13px;"></i> Secure booking</span>
    </div>
  </div>
</div>

<div class="booking-section">
  <div class="booking-grid">

    <!-- LEFT: Form -->
    <div class="booking-main">

      <form id="bookingForm" class="booking-form">
        <input type="hidden" name="offer_id" value="<%= offer.id %>"/>

        <!-- Step 1: Passengers -->
        <section class="bk-step" id="step1">
          <div class="bk-step-header">
            <div class="bk-step-num">1</div>
            <div>
              <h2 class="bk-step-title">Passenger details</h2>
              <p class="bk-step-sub">Names must match passports / government ID exactly.</p>
            </div>
          </div>

          <div id="passengersContainer">
            <% for (let i = 0; i < offer.passenger_count; i++) { %>
              <div class="bk-passenger" data-pax-idx="<%= i %>">
                <div class="bk-pax-header">
                  <i data-lucide="user" style="width:14px;height:14px;color:var(--coral);"></i>
                  Passenger <%= i + 1 %> <span class="bk-pax-type">Adult</span>
                </div>

                <% if (typeof user !== 'undefined' && user && user.saved_travelers && user.saved_travelers.length > 0) { %>
                  <div class="bk-saved-traveler-row">
                    <label class="bk-saved-label">
                      <i data-lucide="bookmark" style="width:11px;height:11px;"></i>
                      Use saved traveler:
                    </label>
                    <select class="bk-saved-traveler" data-pax-target="<%= i %>">
                      <option value="">Choose…</option>
                      <% user.saved_travelers.forEach(t => { %>
                        <option value='<%= JSON.stringify({ title: t.title, given_name: t.given_name, family_name: t.family_name, born_on: t.born_on, gender: t.gender }) %>'>
                          <%= t.given_name %> <%= t.family_name %><%= t.relationship && t.relationship !== 'other' ? ' (' + t.relationship + ')' : '' %>
                        </option>
                      <% }) %>
                    </select>
                  </div>
                <% } %>

                <div class="bk-row">
                  <div class="bk-field bk-field-small">
                    <label class="bk-label">Title</label>
                    <select name="passengers[<%= i %>][title]" class="bk-input" required>
                      <option value="mr">Mr</option>
                      <option value="mrs">Mrs</option>
                      <option value="ms">Ms</option>
                      <option value="miss">Miss</option>
                      <option value="dr">Dr</option>
                    </select>
                  </div>
                  <div class="bk-field">
                    <label class="bk-label">Given (first) name</label>
                    <input type="text" name="passengers[<%= i %>][given_name]" class="bk-input" required autocomplete="given-name"/>
                  </div>
                  <div class="bk-field">
                    <label class="bk-label">Family (last) name</label>
                    <input type="text" name="passengers[<%= i %>][family_name]" class="bk-input" required autocomplete="family-name"/>
                  </div>
                </div>

                <div class="bk-row bk-row-dob">
                  <div class="bk-field bk-field-dob">
                    <label class="bk-label">
                      <span>Date of birth</span>
                      <button type="button" class="bk-dob-toggle" data-dob-toggle="<%= i %>" tabindex="-1">
                        <i data-lucide="calendar" style="width:11px;height:11px;"></i>
                        Use calendar
                      </button>
                    </label>

                    <div class="bk-dob-segments" data-dob-segments="<%= i %>">
                      <input
                        type="text"
                        class="bk-dob-seg bk-dob-mm"
                        data-dob-mm="<%= i %>"
                        placeholder="MM"
                        maxlength="2"
                        inputmode="numeric"
                        autocomplete="bday-month"
                        aria-label="Birth month"
                        required
                      />
                      <span class="bk-dob-sep">/</span>
                      <input
                        type="text"
                        class="bk-dob-seg bk-dob-dd"
                        data-dob-dd="<%= i %>"
                        placeholder="DD"
                        maxlength="2"
                        inputmode="numeric"
                        autocomplete="bday-day"
                        aria-label="Birth day"
                        required
                      />
                      <span class="bk-dob-sep">/</span>
                      <input
                        type="text"
                        class="bk-dob-seg bk-dob-yyyy"
                        data-dob-yyyy="<%= i %>"
                        placeholder="YYYY"
                        maxlength="4"
                        inputmode="numeric"
                        autocomplete="bday-year"
                        aria-label="Birth year"
                        required
                      />
                    </div>

                    <input
                      type="date"
                      class="bk-input bk-dob-native"
                      data-dob-native="<%= i %>"
                      max="<%= new Date().toISOString().slice(0,10) %>"
                      min="1900-01-01"
                      style="display:none;"
                    />

                    <input type="hidden" name="passengers[<%= i %>][born_on]" data-dob-hidden="<%= i %>"/>
                    <div class="bk-dob-error" data-dob-error="<%= i %>"></div>
                  </div>
                  <div class="bk-field">
                    <label class="bk-label">Gender</label>
                    <select name="passengers[<%= i %>][gender]" class="bk-input" required>
                      <option value="m">Male</option>
                      <option value="f">Female</option>
                    </select>
                  </div>
                </div>
                <input type="hidden" name="passengers[<%= i %>][type]" value="adult"/>
              </div>
            <% } %>
          </div>
        </section>

        <!-- Step 2: Contact -->
        <section class="bk-step" id="step2">
          <div class="bk-step-header">
            <div class="bk-step-num">2</div>
            <div>
              <h2 class="bk-step-title">Contact details</h2>
              <p class="bk-step-sub">We'll send your booking confirmation here.</p>
            </div>
          </div>

          <div class="bk-row">
            <div class="bk-field">
              <label class="bk-label">Email</label>
              <input type="email" name="contact_email" id="contactEmail" class="bk-input" required autocomplete="email" placeholder="you@example.com"/>
            </div>
            <div class="bk-field">
              <label class="bk-label">Phone (with country code)</label>
              <input type="tel" name="contact_phone" id="contactPhone" class="bk-input" required autocomplete="tel" placeholder="+1 212 555 0123"/>
              <div class="bk-field-hint">Must start with <strong>+</strong> followed by your country code and full number.</div>
            </div>
          </div>
        </section>

        <!-- Step 3: Extras (seats, bags, preferences) -->
        <section class="bk-step" id="step3">
          <div class="bk-step-header">
            <div class="bk-step-num">3</div>
            <div>
              <h2 class="bk-step-title">Extras <span class="bk-step-opt">(optional)</span></h2>
              <p class="bk-step-sub">Pick seats, add bags, or tell us your preferences. Skip if none needed.</p>
            </div>
          </div>

          <!-- SEATS subsection -->
          <div class="bk-extras-block">
            <div class="bk-extras-head">
              <i data-lucide="armchair" style="width:14px;height:14px;color:var(--coral);"></i>
              <span class="bk-extras-title">Seat selection</span>
            </div>

            <% if (seat_maps && seat_maps.length > 0) { %>
              <p class="bk-extras-sub">Tap an available seat to select it. Prices shown per seat.</p>
              <div id="seatMapsContainer" class="bk-seat-maps"
                   data-seat-maps='<%= JSON.stringify(seat_maps) %>'
                   data-passenger-count="<%= offer.passenger_count %>"
                   data-slice-count="<%= offer.slices.length %>">
                <% offer.slices.forEach((slice, sliceIdx) => { %>
                  <div class="bk-seat-slice" data-slice-idx="<%= sliceIdx %>">
                    <div class="bk-seat-slice-head">
                      <span class="bk-seat-slice-tag"><%= sliceIdx === 0 ? 'Outbound' : 'Return' %></span>
                      <strong><%= slice.origin %> → <%= slice.destination %></strong>
                      <span class="bk-seat-slice-date">· <%= slice.departure_date %></span>
                    </div>
                    <!-- Seat map gets rendered here by booking.js -->
                    <div class="bk-seat-map-render" data-slice-render-idx="<%= sliceIdx %>"></div>
                    <div class="bk-seat-picked" data-slice-picked-idx="<%= sliceIdx %>">
                      <!-- shows "Passenger 1: 12A · $25" etc -->
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <p class="bk-extras-sub">
                <% if (seat_maps_unavailable) { %>
                  Seat selection isn't shown for this fare. Use the box below to tell us your preferences and we'll request them on your behalf.
                <% } else { %>
                  Tell us your seat preferences (window, aisle, extra legroom, etc) and we'll do our best.
                <% } %>
              </p>
              <textarea name="addons[seat_preference_notes]" class="bk-input bk-textarea" rows="2"
                placeholder="e.g. Aisle seat near the front, please. Two travellers together."></textarea>
            <% } %>
          </div>

          <!-- BAGS subsection -->
          <div class="bk-extras-block">
            <div class="bk-extras-head">
              <i data-lucide="luggage" style="width:14px;height:14px;color:var(--coral);"></i>
              <span class="bk-extras-title">Extra baggage</span>
            </div>

            <% if (offer.available_services && offer.available_services.baggage && offer.available_services.baggage.length > 0) { %>
              <p class="bk-extras-sub">Add checked bags per passenger.</p>
              <div id="bagsContainer" class="bk-bags"
                   data-bag-options='<%= JSON.stringify(offer.available_services.baggage) %>'
                   data-passenger-count="<%= offer.passenger_count %>"
                   data-currency="<%= offer.total_currency %>">
                <% for (let i = 0; i < offer.passenger_count; i++) { %>
                  <div class="bk-bag-row" data-bag-pax="<%= i %>">
                    <div class="bk-bag-pax-label">Passenger <%= i + 1 %></div>
                    <div class="bk-bag-options" data-bag-options-pax="<%= i %>"></div>
                  </div>
                <% } %>
              </div>
            <% } else { %>
              <p class="bk-extras-sub">
                Baggage allowances aren't priced via this fare. Tell us what bags you'll bring and we'll add them when ticketing if available.
              </p>
              <textarea name="addons[bag_preference_notes]" class="bk-input bk-textarea" rows="2"
                placeholder="e.g. 1 checked bag (23kg) for each passenger + carry-on."></textarea>
            <% } %>
          </div>
        </section>

        <!-- Step 4: Billing address -->
        <section class="bk-step" id="step4">
          <div class="bk-step-header">
            <div class="bk-step-num">4</div>
            <div>
              <h2 class="bk-step-title">Billing address</h2>
              <p class="bk-step-sub">
                Must match the address on file with your card issuer (helps prevent declines and protects you against fraud).
              </p>
            </div>
          </div>

          <div class="bk-row bk-row-2">
            <div class="bk-field">
              <label class="bk-label">Cardholder full name</label>
              <input type="text" name="billing[name]" id="billingName" class="bk-input" required autocomplete="cc-name" placeholder="As shown on card"/>
              <div class="bk-field-hint">We'll prefill from passenger 1.</div>
            </div>
            <div class="bk-field">
              <label class="bk-label">Billing email <span class="bk-label-opt">(receipt)</span></label>
              <input type="email" name="billing[email]" id="billingEmail" class="bk-input" required autocomplete="email" placeholder="you@example.com"/>
            </div>
          </div>

          <div class="bk-row bk-row-2">
            <div class="bk-field">
              <label class="bk-label">Country</label>
              <select name="billing[country]" id="billingCountry" class="bk-input" required autocomplete="country">
                <option value="">Select country…</option>
                <% countries.forEach((c, i) => { %>
                  <option value="<%= c.code %>" data-name="<%= c.name %>"><%= c.name %></option>
                  <% if (i === 11) { %><option disabled>──────────</option><% } %>
                <% }) %>
              </select>
            </div>
            <div class="bk-field">
              <label class="bk-label">Company <span class="bk-label-opt">(optional, for invoice)</span></label>
              <input type="text" name="billing[company]" id="billingCompany" class="bk-input" autocomplete="organization" placeholder="Acme Inc."/>
            </div>
          </div>

          <div class="bk-field">
            <label class="bk-label">Address line 1</label>
            <input type="text" name="billing[line1]" id="billingLine1" class="bk-input" required autocomplete="address-line1" placeholder="Street and number"/>
          </div>

          <div class="bk-field">
            <label class="bk-label">Address line 2 <span class="bk-label-opt">(optional)</span></label>
            <input type="text" name="billing[line2]" id="billingLine2" class="bk-input" autocomplete="address-line2" placeholder="Apartment, suite, unit, building, floor, etc."/>
          </div>

          <div class="bk-row bk-row-3">
            <div class="bk-field">
              <label class="bk-label">City</label>
              <input type="text" name="billing[city]" id="billingCity" class="bk-input" required autocomplete="address-level2"/>
            </div>
            <div class="bk-field">
              <label class="bk-label">State / Region</label>
              <input type="text" name="billing[state]" id="billingState" class="bk-input" required autocomplete="address-level1"/>
            </div>
            <div class="bk-field">
              <label class="bk-label">ZIP / Postal code</label>
              <input type="text" name="billing[postal_code]" id="billingPostal" class="bk-input" required autocomplete="postal-code"/>
            </div>
          </div>
        </section>

        <!-- Step 5: Payment -->
        <section class="bk-step" id="step5">
          <div class="bk-step-header">
            <div class="bk-step-num">5</div>
            <div>
              <h2 class="bk-step-title">Payment</h2>
              <p class="bk-step-sub">
                <i data-lucide="lock" style="width:11px;height:11px;color:var(--coral);vertical-align:-1px;"></i>
                Secure 3D-Secure payment via Stripe. Your card details never touch our servers.
              </p>
            </div>
          </div>

          <div id="paymentSection" class="bk-payment-locked">
            <div class="bk-payment-locked-msg">
              <i data-lucide="lock" style="width:14px;height:14px;"></i>
              <span>Complete passenger, contact, and billing details above to enable payment.</span>
            </div>
          </div>

          <div id="paymentElement" class="bk-stripe-element" style="display:none;"></div>
          <div id="paymentMessage" class="bk-payment-message" style="display:none;"></div>

          <button type="submit" id="payBtn" class="btn-coral bk-pay-btn" disabled>
            <i data-lucide="lock" style="width:14px;height:14px;"></i>
            <span id="payBtnLabel">Pay securely</span>
            <i data-lucide="arrow-right" style="width:14px;height:14px;"></i>
          </button>

          <div class="bk-trust-row">
            <div class="bk-trust">
              <i data-lucide="shield-check" style="width:13px;height:13px;"></i>
              <span>PCI-DSS compliant via Stripe</span>
            </div>
            <div class="bk-trust">
              <i data-lucide="check-circle-2" style="width:13px;height:13px;"></i>
              <span>3D Secure protected</span>
            </div>
            <div class="bk-trust">
              <i data-lucide="globe" style="width:13px;height:13px;"></i>
              <span>IP risk verified</span>
            </div>
          </div>
        </section>
      </form>
    </div>

    <!-- RIGHT: Order summary -->
    <aside class="booking-sidebar">
      <div class="bk-summary">
        <div class="bk-summary-header">
          <% if (offer.carrier_logo) { %>
            <img src="<%= offer.carrier_logo %>" alt="<%= offer.carrier %>" class="bk-carrier-logo"/>
          <% } else { %>
            <div class="bk-carrier-fallback"><%= offer.carrier_iata %></div>
          <% } %>
          <div>
            <div class="bk-carrier-name"><%= offer.carrier %></div>
            <div class="bk-carrier-pax"><%= offer.passenger_count %> passenger<%= offer.passenger_count > 1 ? 's' : '' %></div>
          </div>
        </div>

        <% offer.slices.forEach((slice, idx) => { %>
          <div class="bk-slice <%= idx > 0 ? 'bk-slice-return' : '' %>">
            <div class="bk-slice-tag"><%= idx === 0 ? 'Outbound' : 'Return' %></div>
            <div class="bk-slice-row">
              <div>
                <div class="bk-slice-time"><%= slice.departure_time %></div>
                <div class="bk-slice-iata"><%= slice.origin %></div>
              </div>
              <div class="bk-slice-path">
                <div class="bk-slice-duration"><%= slice.duration %></div>
                <div class="bk-slice-line"></div>
                <div class="bk-slice-stops"><%= slice.stops === 0 ? 'Direct' : `${slice.stops} stop${slice.stops > 1 ? 's' : ''}` %></div>
              </div>
              <div style="text-align:right;">
                <div class="bk-slice-time"><%= slice.arrival_time %></div>
                <div class="bk-slice-iata"><%= slice.destination %></div>
              </div>
            </div>
            <div class="bk-slice-date">
              <i data-lucide="calendar" style="width:11px;height:11px;"></i>
              <%= slice.departure_date %>
            </div>
          </div>
        <% }) %>

        <div class="bk-price-block">
          <div class="bk-price-line">
            <span>Base fare</span>
            <span><%= offer.total_currency === 'EUR' ? '€' : (offer.total_currency === 'USD' ? '$' : '£') %><%= Math.round(parseFloat(offer.base_amount)) %></span>
          </div>
          <div class="bk-price-line">
            <span>Taxes &amp; fees</span>
            <span><%= offer.total_currency === 'EUR' ? '€' : (offer.total_currency === 'USD' ? '$' : '£') %><%= Math.round(parseFloat(offer.tax_amount)) %></span>
          </div>
          <div class="bk-price-divider"></div>
          <div class="bk-price-total">
            <span>Total</span>
            <span class="bk-price-total-big">
              <%= offer.total_currency === 'EUR' ? '€' : (offer.total_currency === 'USD' ? '$' : '£') %><%= Math.round(parseFloat(offer.total_amount)) %>
            </span>
          </div>
        </div>

        <div class="bk-expires">
          <i data-lucide="clock" style="width:11px;height:11px;"></i>
          Offer expires <%= new Date(offer.expires_at).toLocaleString('en-US', { hour: '2-digit', minute: '2-digit', day: 'numeric', month: 'short' }) %>
        </div>
      </div>

      <!-- Affiliate add-on cards -->
      <% const enabledAffiliates = Object.entries(affiliates).filter(([_, a]) => a.enabled); %>
      <% if (enabledAffiliates.length > 0) { %>
        <div class="bk-affiliates">
          <div class="bk-affiliates-head">Make your trip easier</div>
          <% enabledAffiliates.forEach(([key, aff]) => { %>
            <a href="<%= aff.url %>" target="_blank" rel="noopener nofollow sponsored"
               class="bk-affiliate-card"
               data-affiliate="<%= key %>">
              <div class="bk-affiliate-body">
                <div class="bk-affiliate-headline"><%= aff.headline %></div>
                <div class="bk-affiliate-sub"><%= aff.sub %></div>
                <% if (aff.note) { %><div class="bk-affiliate-note"><%= aff.note %></div><% } %>
              </div>
              <div class="bk-affiliate-cta">
                <%= aff.cta %>
                <i data-lucide="external-link" style="width:11px;height:11px;"></i>
              </div>
            </a>
          <% }) %>
          <div class="bk-affiliates-foot">
            Some links are affiliate referrals. Booking through them helps support FlightDojo at no extra cost to you.
          </div>
        </div>
      <% } %>

    </aside>

  </div>
</div>

<script src="https://js.stripe.com/v3/"></script>
<script>
  window.FD_OFFER = {
    id: '<%= offer.id %>',
    total: '<%= offer.total_amount %>',
    currency: '<%= offer.total_currency %>',
    passenger_count: <%= offer.passenger_count %>
  };
  window.FD_STRIPE_PK = '<%= stripePublishableKey %>';
</script>
<script src="/js/booking.js?v=<%= typeof assetVersion !== "undefined" ? assetVersion : "1" %>"></script>

<%- include('partials/footer') %>
