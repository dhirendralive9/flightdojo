<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="auth-section">
  <div class="auth-card">
    <div class="auth-eyebrow">New password</div>
    <h1 class="auth-title">Set a new password</h1>
    <p class="auth-sub">Choose something you'll remember. Minimum 8 characters.</p>

    <form id="resetForm" class="auth-form" data-token="<%= token %>">
      <div class="auth-field">
        <label>New password</label>
        <input type="password" name="password" required autocomplete="new-password" minlength="8" autofocus/>
      </div>
      <div class="auth-field">
        <label>Confirm new password</label>
        <input type="password" name="password_confirm" required autocomplete="new-password" minlength="8"/>
      </div>
      <button type="submit" class="btn-coral auth-submit">
        <span class="auth-submit-label">Save and sign in</span>
        <i data-lucide="arrow-right" style="width:14px;height:14px;"></i>
      </button>
      <div class="auth-msg"></div>
    </form>
  </div>
</div>

<script src="/js/account.js?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : '1' %>"></script>
<%- include('partials/footer') %>
