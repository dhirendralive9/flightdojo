<%- include('partials/head') %>
<%- include('partials/navbar') %>

<%- include('partials/page-header', {
  eyebrow: 'Careers',
  title: 'Join The<br/><em>Dojo</em>',
  sub: 'We\'re a small, distributed team building flight search the right way. If you care about transparency, precision, and craft — we want to talk to you.'
}) %>

<section class="section reveal">
  <div style="max-width:900px;margin:0 auto 56px;">
    <div class="sec-eyebrow">Open Roles</div>
    <div class="sec-title" style="margin-bottom:24px;">Currently Hiring</div>
    <p style="font-size:15px;color:var(--text-muted);line-height:1.8;max-width:640px;">We hire slowly and carefully. If you don't see your role below, send us a note anyway — strong people always have a place at FlightDojo.</p>
  </div>

  <div class="jobs-list stagger">
    <div class="job-card">
      <div class="job-info">
        <span class="job-tag">Engineering</span>
        <div class="job-title">Senior Backend Engineer</div>
        <div class="job-meta">
          <span><i data-lucide="map-pin" style="width:14px;height:14px;"></i> Remote · Worldwide</span>
          <span><i data-lucide="clock" style="width:14px;height:14px;"></i> Full-time</span>
          <span><i data-lucide="banknote" style="width:14px;height:14px;"></i> $140k – $180k</span>
        </div>
      </div>
      <div class="job-arrow"><i data-lucide="arrow-up-right" style="width:18px;height:18px;"></i></div>
    </div>

    <div class="job-card">
      <div class="job-info">
        <span class="job-tag">Engineering</span>
        <div class="job-title">Frontend Engineer (React)</div>
        <div class="job-meta">
          <span><i data-lucide="map-pin" style="width:14px;height:14px;"></i> Remote · EU / Asia</span>
          <span><i data-lucide="clock" style="width:14px;height:14px;"></i> Full-time</span>
          <span><i data-lucide="banknote" style="width:14px;height:14px;"></i> $110k – $150k</span>
        </div>
      </div>
      <div class="job-arrow"><i data-lucide="arrow-up-right" style="width:18px;height:18px;"></i></div>
    </div>

    <div class="job-card">
      <div class="job-info">
        <span class="job-tag">Operations</span>
        <div class="job-title">Customer Support Lead</div>
        <div class="job-meta">
          <span><i data-lucide="map-pin" style="width:14px;height:14px;"></i> Remote · Worldwide</span>
          <span><i data-lucide="clock" style="width:14px;height:14px;"></i> Full-time</span>
          <span><i data-lucide="banknote" style="width:14px;height:14px;"></i> $70k – $95k</span>
        </div>
      </div>
      <div class="job-arrow"><i data-lucide="arrow-up-right" style="width:18px;height:18px;"></i></div>
    </div>

    <div class="job-card">
      <div class="job-info">
        <span class="job-tag">Design</span>
        <div class="job-title">Product Designer</div>
        <div class="job-meta">
          <span><i data-lucide="map-pin" style="width:14px;height:14px;"></i> Remote · Worldwide</span>
          <span><i data-lucide="clock" style="width:14px;height:14px;"></i> Full-time</span>
          <span><i data-lucide="banknote" style="width:14px;height:14px;"></i> $120k – $160k</span>
        </div>
      </div>
      <div class="job-arrow"><i data-lucide="arrow-up-right" style="width:18px;height:18px;"></i></div>
    </div>

    <div class="job-card">
      <div class="job-info">
        <span class="job-tag">Data</span>
        <div class="job-title">Travel Data Analyst</div>
        <div class="job-meta">
          <span><i data-lucide="map-pin" style="width:14px;height:14px;"></i> Remote · Worldwide</span>
          <span><i data-lucide="clock" style="width:14px;height:14px;"></i> Full-time</span>
          <span><i data-lucide="banknote" style="width:14px;height:14px;"></i> $90k – $130k</span>
        </div>
      </div>
      <div class="job-arrow"><i data-lucide="arrow-up-right" style="width:18px;height:18px;"></i></div>
    </div>
  </div>
</section>

<section class="section values-section">
  <div class="reveal" style="text-align:center;max-width:680px;margin:0 auto 48px;">
    <div class="sec-eyebrow" style="justify-content:center;">Why FlightDojo</div>
    <div class="sec-title" style="margin-bottom:0;">Perks &amp; Benefits</div>
  </div>

  <div class="perks-grid stagger">
    <div class="perk">
      <div class="perk-icon"><i data-lucide="globe-2" style="width:20px;height:20px;"></i></div>
      <div class="perk-title">Remote first</div>
      <div class="perk-desc">Work from anywhere. We've been remote since day one.</div>
    </div>
    <div class="perk">
      <div class="perk-icon"><i data-lucide="plane" style="width:20px;height:20px;"></i></div>
      <div class="perk-title">Travel stipend</div>
      <div class="perk-desc">$5,000/yr to fly anywhere. Yes, we eat our own cooking.</div>
    </div>
    <div class="perk">
      <div class="perk-icon"><i data-lucide="heart-pulse" style="width:20px;height:20px;"></i></div>
      <div class="perk-title">Health coverage</div>
      <div class="perk-desc">Premium health, dental &amp; vision for you and your family.</div>
    </div>
    <div class="perk">
      <div class="perk-icon"><i data-lucide="trending-up" style="width:20px;height:20px;"></i></div>
      <div class="perk-title">Equity</div>
      <div class="perk-desc">Every full-time hire gets meaningful equity. Build with us.</div>
    </div>
    <div class="perk">
      <div class="perk-icon"><i data-lucide="book-open" style="width:20px;height:20px;"></i></div>
      <div class="perk-title">Learning budget</div>
      <div class="perk-desc">$2,000/yr for books, courses, conferences — your call.</div>
    </div>
    <div class="perk">
      <div class="perk-icon"><i data-lucide="laptop" style="width:20px;height:20px;"></i></div>
      <div class="perk-title">Top-tier gear</div>
      <div class="perk-desc">Latest MacBook + monitor + chair. Or pick your own setup.</div>
    </div>
    <div class="perk">
      <div class="perk-icon"><i data-lucide="palmtree" style="width:20px;height:20px;"></i></div>
      <div class="perk-title">Unlimited PTO</div>
      <div class="perk-desc">Take what you need. Minimum 4 weeks — we enforce that.</div>
    </div>
    <div class="perk">
      <div class="perk-icon"><i data-lucide="users" style="width:20px;height:20px;"></i></div>
      <div class="perk-title">Team offsites</div>
      <div class="perk-desc">Twice a year we gather somewhere beautiful. On us.</div>
    </div>
  </div>
</section>

<div class="deals-section reveal">
  <div>
    <div class="deals-tag">Get In Touch</div>
    <div class="deals-title">Don't See<br/>Your Role?</div>
    <div class="deals-sub">Send us a note. Tell us what you do and why FlightDojo.</div>
  </div>
  <div>
    <a href="/contact" class="btn-outline" style="background:#fff;color:var(--coral);border-color:#fff;padding:14px 28px;font-size:12px;">
      Contact Us <i data-lucide="arrow-right" style="width:14px;height:14px;"></i>
    </a>
  </div>
</div>

<%- include('partials/footer') %>
