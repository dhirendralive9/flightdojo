<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="auth-section">
  <div class="auth-card" style="text-align:center;">
    <% if (success) { %>
      <div class="bks-icon bks-icon-success" style="margin:0 auto 18px;">
        <i data-lucide="check" style="width:36px;height:36px;"></i>
      </div>
      <h1 class="auth-title">You're in</h1>
      <p class="auth-sub"><%= message %></p>
      <a href="/account/groups" class="btn-coral" style="margin-top:18px;">Go to my groups</a>
    <% } else { %>
      <div class="bks-icon bks-icon-failed" style="margin:0 auto 18px;">
        <i data-lucide="x" style="width:36px;height:36px;"></i>
      </div>
      <h1 class="auth-title">Invitation issue</h1>
      <p class="auth-sub"><%= message %></p>
      <a href="/account" class="btn-coral" style="margin-top:18px;">Go to dashboard</a>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
