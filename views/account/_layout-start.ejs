<div class="account-section">
  <aside class="account-sidebar">
    <div class="account-user-card">
      <div class="account-avatar"><%= ((user.name || user.email)[0] || '?').toUpperCase() %></div>
      <div class="account-user-meta">
        <div class="account-user-name"><%= user.name || user.email %></div>
        <% if (user.name) { %><div class="account-user-email"><%= user.email %></div><% } %>
      </div>
    </div>
    <nav class="account-nav">
      <a href="/account" class="<%= active_section === 'trips' ? 'active' : '' %>">
        <i data-lucide="ticket" style="width:14px;height:14px;"></i>
        My trips
      </a>
      <a href="/account/notifications" class="<%= active_section === 'notifications' ? 'active' : '' %>">
        <i data-lucide="bell" style="width:14px;height:14px;"></i>
        Notifications
        <% if (typeof unread_notifications !== 'undefined' && unread_notifications > 0) { %>
          <span class="nav-badge"><%= unread_notifications %></span>
        <% } %>
      </a>
      <a href="/account/saved-searches" class="<%= active_section === 'saved-searches' ? 'active' : '' %>">
        <i data-lucide="star" style="width:14px;height:14px;"></i>
        Saved searches
      </a>
      <a href="/account/groups" class="<%= active_section === 'groups' ? 'active' : '' %>">
        <i data-lucide="users" style="width:14px;height:14px;"></i>
        Groups
      </a>
      <a href="/account/travelers" class="<%= active_section === 'travelers' ? 'active' : '' %>">
        <i data-lucide="user-check" style="width:14px;height:14px;"></i>
        Travelers
      </a>
      <a href="/account/payment-methods" class="<%= active_section === 'payment-methods' ? 'active' : '' %>">
        <i data-lucide="credit-card" style="width:14px;height:14px;"></i>
        Payment methods
      </a>
      <a href="/account/refer" class="<%= active_section === 'refer' ? 'active' : '' %> nav-refer">
        <i data-lucide="gift" style="width:14px;height:14px;"></i>
        Refer a friend
      </a>
      <a href="/account/settings" class="<%= active_section === 'settings' ? 'active' : '' %>">
        <i data-lucide="settings" style="width:14px;height:14px;"></i>
        Settings
      </a>
      <a href="/contact" class="<%= active_section === 'support' ? 'active' : '' %>">
        <i data-lucide="headphones" style="width:14px;height:14px;"></i>
        Support
      </a>
      <a href="/logout" class="account-nav-logout">
        <i data-lucide="log-out" style="width:14px;height:14px;"></i>
        Sign out
      </a>
    </nav>
  </aside>
  <main class="account-main">
