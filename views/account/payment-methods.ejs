<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<%- include('_layout-start') %>

<div class="account-header">
  <h1 class="account-h1">Payment methods</h1>
  <p class="account-sub">Cards you've used to pay are saved by Stripe for faster checkout. Remove any you no longer use.</p>
</div>

<% if (methods.length === 0) { %>
  <div class="account-empty">
    <div class="account-empty-icon">
      <i data-lucide="credit-card" style="width:36px;height:36px;"></i>
    </div>
    <h2>No cards saved yet</h2>
    <p>Cards you pay with are saved automatically. Book a trip to add your first one.</p>
    <a href="/" class="btn-coral" style="margin-top:16px;">
      <i data-lucide="search" style="width:14px;height:14px;"></i>
      Search flights
    </a>
  </div>
<% } else { %>
  <% const brandLabel = { visa: 'Visa', mastercard: 'Mastercard', amex: 'American Express', discover: 'Discover', diners: 'Diners', jcb: 'JCB', unionpay: 'UnionPay' }; %>
  <div class="pm-list">
    <% methods.forEach(m => { %>
      <div class="pm-card" data-pm="<%= m.id %>">
        <div class="pm-brand pm-brand-<%= m.brand %>">
          <%= (brandLabel[m.brand] || m.brand).slice(0, 4).toUpperCase() %>
        </div>
        <div class="pm-info">
          <div class="pm-number">•••• •••• •••• <%= m.last4 %></div>
          <div class="pm-meta">
            <%= brandLabel[m.brand] || m.brand %> · Expires <%= String(m.exp_month).padStart(2, '0') %>/<%= String(m.exp_year).slice(-2) %>
            <% if (m.country) { %> · <%= m.country %><% } %>
          </div>
        </div>
        <button class="pm-remove" data-remove="<%= m.id %>" aria-label="Remove card">
          <i data-lucide="trash-2" style="width:13px;height:13px;"></i>
          Remove
        </button>
      </div>
    <% }) %>
  </div>
  <p class="pm-footnote">
    Card details are stored securely by Stripe. We never see or store your full card number.
  </p>
<% } %>

<script src="/js/account-payment.js?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : '1' %>"></script>
<%- include('_layout-end') %>
<%- include('../partials/footer') %>
