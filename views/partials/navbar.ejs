<% if (ribbon && ribbon.enabled) { %>
<div class="top-ribbon">
  <div class="top-ribbon-inner">
    <div class="top-ribbon-message">
      <i data-lucide="headphones" style="width:13px;height:13px;"></i>
      <span><%= ribbon.message %></span>
    </div>
    <div class="top-ribbon-actions">
      <a href="tel:<%= ribbon.phone_tel %>" class="top-ribbon-link">
        <i data-lucide="phone" style="width:12px;height:12px;"></i>
        <span><%= ribbon.phone_display %></span>
      </a>
      <span class="top-ribbon-divider" aria-hidden="true">·</span>
      <a href="/contact" class="top-ribbon-link">
        <i data-lucide="mail" style="width:12px;height:12px;"></i>
        <span>Contact us</span>
      </a>
    </div>
  </div>
</div>
<% } %>

<nav class="navbar">
  <a href="/" class="logo">Flight<em>Dojo</em></a>
  <ul class="nav-center">
    <% navLinks.forEach(link => { %>
      <li><a href="<%= link.href %>" class="<%= currentPath === link.href ? 'active' : '' %>"><%= link.label %></a></li>
    <% }) %>
  </ul>
  <div class="nav-right">
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
      <i data-lucide="sun" class="icon-sun" style="width:16px;height:16px;"></i>
      <i data-lucide="moon" class="icon-moon" style="width:16px;height:16px;"></i>
    </button>
    <% if (typeof user !== 'undefined' && user) { %>
      <a href="/account" class="btn-ghost-nav">
        <i data-lucide="user" style="width:14px;height:14px;"></i>
        My trips
      </a>
    <% } else { %>
      <a href="/login" class="btn-ghost-nav">Sign in</a>
    <% } %>
    <a href="/" class="btn-coral">Search Flights</a>
    <button class="hamburger" id="hamburger" aria-label="Menu">
      <i data-lucide="menu" style="width:22px;height:22px;"></i>
    </button>
  </div>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <% navLinks.forEach(link => { %>
    <a href="<%= link.href %>" class="<%= currentPath === link.href ? 'active' : '' %>"><%= link.label %></a>
  <% }) %>
  <a href="/" class="btn-coral mobile-only">Search Flights</a>
</div>
