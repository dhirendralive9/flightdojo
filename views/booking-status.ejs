<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="booking-status-section">
  <div class="bks-card">

    <% if (typeof access_denied !== 'undefined' && access_denied) { %>
      <!-- Order exists but viewer is not authorized. Ask for the email used on the booking. -->
      <div class="bks-state">
        <div class="bks-icon bks-icon-loading">
          <i data-lucide="lock" style="width:36px;height:36px;"></i>
        </div>
        <h1 class="bks-title">Verify your booking</h1>
        <p class="bks-sub">
          To view order <code><%= reference %></code>, please enter the email address used at booking.
          <% if (typeof contact_email_hint !== 'undefined' && contact_email_hint) { %>
            <br/><small style="color:var(--text-muted);">Hint: <%= contact_email_hint %></small>
          <% } %>
        </p>
        <form method="get" action="/booking/<%= reference %>" style="margin-top:18px;max-width:380px;margin-left:auto;margin-right:auto;">
          <div style="display:flex;gap:8px;">
            <input type="email" name="email" required placeholder="email@example.com"
                   style="flex:1;background:var(--surface);border:1px solid var(--border);border-radius:5px;padding:11px 14px;font-family:'Outfit',sans-serif;font-size:13px;color:var(--text);outline:none;"/>
            <button type="submit" class="btn-coral" style="padding:11px 18px;">
              View
            </button>
          </div>
        </form>
        <p style="margin-top:18px;font-size:12px;color:var(--text-muted);">
          Or <a href="/login?next=<%= encodeURIComponent('/account/bookings/' + reference) %>" style="color:var(--coral);">sign in</a> if you have an account.
        </p>
      </div>
    <% } else if (!order) { %>
      <!-- Order not found at all -->
      <div class="bks-state">
        <div class="bks-icon bks-icon-failed">
          <i data-lucide="search-x" style="width:36px;height:36px;"></i>
        </div>
        <h1 class="bks-title">Booking not found</h1>
        <p class="bks-sub">
          We couldn't find order <code><%= reference %></code>. Double-check the order ID,
          or <a href="/contact" style="color:var(--coral);">contact support</a>.
        </p>
      </div>
    <% } else { %>

    <%
      const isFinished = order && ['booked', 'ticketed', 'completed'].includes(order.status);
      const isFailed = order && ['failed', 'cancelled'].includes(order.status);
    %>
    <div id="bksLoading" class="bks-state" style="<%= isFinished || isFailed ? 'display:none;' : '' %>">
      <div class="bks-icon bks-icon-loading">
        <i data-lucide="loader" style="width:36px;height:36px;"></i>
      </div>
      <h1 class="bks-title">Finalising your booking…</h1>
      <p class="bks-sub">
        Payment received. We're now confirming with the airline and issuing your ticket.
        This usually takes 10–30 seconds. <strong>Don't close this page.</strong>
      </p>
      <div class="bks-progress"><div class="bks-progress-bar"></div></div>
      <div class="bks-ref-line">
        Order ID <code><%= reference %></code>
      </div>
    </div>

    <div id="bksSuccess" class="bks-state" style="<%= isFinished ? '' : 'display:none;' %>">
      <div class="bks-icon bks-icon-success">
        <i data-lucide="check" style="width:42px;height:42px;"></i>
      </div>
      <div class="bks-eyebrow">Confirmed</div>
      <h1 class="bks-title">Booking received.</h1>
      <p class="bks-sub">
        Thank you. We've received your booking and payment. A confirmation email
        is on its way to <strong><%= order ? order.contact_email : '' %></strong>,
        and your airline booking reference (PNR) will follow within 2 business hours.
      </p>

      <% if (order) { %>
        <div class="bks-pnr">
          <div class="bks-pnr-label">FlightDojo Order ID</div>
          <div class="bks-pnr-code"><%= order.reference %></div>
        </div>

        <div class="bks-trip-summary">
          <% (order.slices || []).forEach((slice, idx) => { %>
            <div class="bks-trip-row">
              <div class="bks-trip-tag"><%= idx === 0 ? 'Outbound' : 'Return' %></div>
              <div class="bks-trip-route">
                <strong><%= slice.origin %></strong>
                <i data-lucide="arrow-right" style="width:13px;height:13px;color:var(--coral);vertical-align:-2px;"></i>
                <strong><%= slice.destination %></strong>
                <span class="bks-trip-date">· <%= slice.departure_date %></span>
              </div>
            </div>
          <% }) %>
        </div>

        <div class="bks-actions">
          <a href="/" class="btn-coral" style="padding:12px 22px;">
            <i data-lucide="search" style="width:14px;height:14px;"></i>
            Book another trip
          </a>
          <a href="/contact" class="btn-ghost-hero" style="padding:12px 22px;">
            <i data-lucide="headphones" style="width:13px;height:13px;"></i>
            Get support
          </a>
        </div>

        <!-- Inline account-creation card (only for logged-out users) -->
        <% if (typeof user === 'undefined' || !user) { %>
          <div id="inlineSignupCard" class="bks-signup-card">
            <div class="bks-signup-head">
              <i data-lucide="user-plus" style="width:18px;height:18px;color:var(--coral);"></i>
              <h3>Save this booking — create an account in 30 seconds</h3>
            </div>
            <p class="bks-signup-sub">
              Track this trip and all future bookings in one dashboard. We'll auto-fill your details next time.
            </p>
            <form id="inlineSignupForm" class="bks-signup-form">
              <input type="hidden" name="email" value="<%= order ? order.contact_email : '' %>"/>
              <input type="hidden" name="name" value="<%= order && order.passengers && order.passengers[0] ? ((order.passengers[0].given_name || '') + ' ' + (order.passengers[0].family_name || '')).trim() : '' %>"/>
              <div class="bks-signup-emaildisplay">
                <i data-lucide="mail" style="width:13px;height:13px;color:var(--text-muted);"></i>
                <%= order ? order.contact_email : '' %>
              </div>
              <div class="bks-signup-fields">
                <input type="password" name="password" required minlength="8" placeholder="Choose a password (8+)" class="bk-input" autocomplete="new-password"/>
                <input type="password" name="password_confirm" required minlength="8" placeholder="Confirm password" class="bk-input" autocomplete="new-password"/>
              </div>
              <button type="submit" class="btn-coral bks-signup-btn">
                <i data-lucide="user-plus" style="width:14px;height:14px;"></i>
                <span class="auth-submit-label">Create account</span>
              </button>
              <div class="auth-msg"></div>
            </form>
            <div class="bks-signup-foot">
              Already have an account? <a href="/login">Sign in</a>
            </div>
          </div>

          <div id="inlineSignupSuccess" class="bks-signup-success" style="display:none;">
            <i data-lucide="check-circle" style="width:24px;height:24px;color:var(--coral);"></i>
            <div>
              <strong>Account created!</strong>
              <span>We've linked <span id="inlineSignupLinkedCount">1</span> booking to your account.</span>
              <a href="/account" class="bks-signup-success-cta">View my dashboard →</a>
            </div>
          </div>
        <% } else { %>
          <!-- Logged-in users get a direct link to their dashboard -->
          <div class="bks-signup-card" style="background:var(--bg-2);">
            <p class="bks-signup-sub" style="margin:0 0 12px;">This booking has been added to your account.</p>
            <a href="/account" class="btn-coral bks-signup-btn">
              <i data-lucide="layout-dashboard" style="width:14px;height:14px;"></i>
              View my trips
            </a>
          </div>
        <% } %>
      <% } %>
    </div>

    <div id="bksFailed" class="bks-state" style="<%= isFailed ? '' : 'display:none;' %>">
      <div class="bks-icon bks-icon-failed">
        <i data-lucide="x" style="width:36px;height:36px;"></i>
      </div>
      <h1 class="bks-title">We hit a snag</h1>
      <p class="bks-sub" id="bksFailMsg">
        Your payment went through but we couldn't issue the ticket. Don't worry — you have not been charged twice. Our team will reach out within 1 business hour.
      </p>
      <div class="bks-ref-line">
        Order ID <code><%= reference %></code>
      </div>
      <div class="bks-actions">
        <a href="/contact" class="btn-coral" style="padding:12px 22px;">
          <i data-lucide="headphones" style="width:13px;height:13px;"></i>
          Contact support
        </a>
      </div>
    </div>

    <% } %>

  </div>
</div>

<script>
  window.FD_BOOKING_REFERENCE = '<%= reference %>';
  window.FD_INITIAL_STATUS = '<%= order ? order.status : "pending" %>';
</script>
<script src="/js/booking-status.js?v=<%= typeof assetVersion !== "undefined" ? assetVersion : "1" %>"></script>
<script src="/js/account.js?v=<%= typeof assetVersion !== "undefined" ? assetVersion : "1" %>"></script>

<%- include('partials/footer') %>
