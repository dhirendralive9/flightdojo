# Duffel test mode access token (starts with duffel_test_)
# Get yours at https://app.duffel.com/ → Developers → Access Tokens
DUFFEL_ACCESS_TOKEN=duffel_test_REPLACE_ME

# Cloudflare Turnstile keys
# Defaults below are Cloudflare's dummy "always pass" keys for development.
# Production: get your real keys at https://dash.cloudflare.com → Turnstile → Add Site
TURNSTILE_SITEKEY=1x00000000000000000000AA
TURNSTILE_SECRET=1x0000000000000000000000000000000AA

# Airport database
# Set to 1 to fetch the full ~10,000-airport dataset from Travelpayouts on startup.
# Leave unset to use the bundled curated list (~280 major airports worldwide).
AIRPORTS_USE_REMOTE=0

# Server config
PORT=3000
NODE_ENV=development
