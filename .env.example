# ─── Duffel API ───
# Get your token at https://app.duffel.com/ → Developers → Access Tokens
DUFFEL_ACCESS_TOKEN=duffel_test_REPLACE_ME

# ─── Cloudflare Turnstile ───
# Defaults are Cloudflare's dummy "always pass" keys for development.
TURNSTILE_SITEKEY=1x00000000000000000000AA
TURNSTILE_SECRET=1x0000000000000000000000000000000AA

# ─── Stripe ───
# Get your sandbox/test keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
# Get this when you set up the webhook: https://dashboard.stripe.com/test/webhooks
# For local dev with `stripe listen`, paste the signing secret it shows you.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ─── ProxyCheck.io v3 (IP risk gate before payment) ───
# Get a free API key (1,000 lookups/day) at https://proxycheck.io/dashboard
# Without a key, the booking flow runs in PERMISSIVE mode (all IPs allowed).
PROXYCHECK_API_KEY=

# ─── MongoDB ───
# Local: mongodb://localhost:27017/flightdojo
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/flightdojo
MONGODB_URI=mongodb://localhost:27017/flightdojo

# ─── SMTP (Nodemailer) ───
# For development, sign up for free at https://mailtrap.io and grab the SMTP credentials
# from any inbox. They'll catch all outgoing email so you can preview without sending.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=REPLACE_ME
SMTP_PASS=REPLACE_ME
SMTP_FROM="FlightDojo <noreply@flightdojo.it.com>"

# ─── Airport database ───
# Set to 1 to fetch the full ~10,000-airport dataset from Travelpayouts on startup.
AIRPORTS_USE_REMOTE=0

# ─── Server config ───
PORT=3000
NODE_ENV=development
# Public base URL — used in Stripe success/cancel URLs and email links
BASE_URL=https://flightdojo.it.com

# ─── Affiliate add-on cards ───
# Sign up at each provider, get your affiliate URL, paste below.
# Leave blank to hide the card.
#
# eSIM — Airalo Partners: https://www.airalo.com/partners
AIRALO_AFFILIATE_URL=
# Airport lounges — Priority Pass / LoungeBuddy / DragonPass / Plaza Premium
LOUNGES_AFFILIATE_URL=
# Hotels — Booking.com Partners: https://www.booking.com/affiliate
HOTELS_AFFILIATE_URL=
# Airport transfers — GetTransfer / Welcome Pickups / Booking.com Cars
TRANSFERS_AFFILIATE_URL=
# Travel insurance — XCover (Cover Genius) / HeyMondo / etc.
INSURANCE_AFFILIATE_URL=

# ─── Top ribbon (phone + contact link above main nav) ───
# Set RIBBON_ENABLED=false to hide it entirely.
RIBBON_ENABLED=true
# What's shown to the user (formatted nicely with spaces/parens)
SUPPORT_PHONE_DISPLAY=+1 (888) 555-0199
# What's used in the tel: link (digits only, with leading +)
SUPPORT_PHONE_TEL=+18885550199
# Optional tagline shown on the left side of the ribbon (hidden on mobile)
RIBBON_MESSAGE=Need help booking? Speak with a travel specialist.

# ─── Sessions (required for auth/dashboard) ───
# Random 32+ character string. Generate with: openssl rand -hex 32
SESSION_SECRET=

# ─── Tier 2: passport docs + weather ───
# 32+ char string used to derive AES-256 key for passport file encryption-at-rest.
# Generate with: openssl rand -hex 32
# Leave blank during dev — files stored unencrypted (with a warning on boot).
PASSPORT_ENCRYPTION_KEY=

# Free tier from https://openweathermap.org/api
# Used for day-of-travel weather snapshot on trip detail pages.
# Leave blank to hide the weather card.
OPENWEATHER_API_KEY=

# ─── Tier 3: referrals, saved searches, groups ───
# Cron schedule for daily price-alert check. Default: 09:00 UTC daily.
# Use https://crontab.guru to design your own.
PRICE_ALERT_CRON=0 9 * * *

# Disable cron entirely (e.g. on a worker-less host or for dev)
# DISABLE_CRON=1

# ─── Tier A admin: Stripe dashboard link ───
# Used in admin order-detail to link from a PaymentIntent ID directly to Stripe.
# Default: https://dashboard.stripe.com/test/payments
# For live: https://dashboard.stripe.com/acct_YOUR_ACCT_ID/payments
STRIPE_DASHBOARD_URL=https://dashboard.stripe.com/test/payments

# ─── Cookie security (Cloudflare gotcha) ───
# By default, cookies are 'secure' (HTTPS-only) in production.
# If your origin runs behind Cloudflare in "Flexible SSL" mode (CF serves HTTPS
# but talks HTTP to your origin), you may need to set this to false otherwise
# login sessions won't persist. Use "Full" or "Full (strict)" SSL mode on
# Cloudflare and leave this unset, OR set COOKIE_SECURE=false.
# COOKIE_SECURE=true

# ─── Admin bootstrap (auto-create admin user from env) ───
# Idempotent — safe to leave in .env permanently.
# On every server boot, ensures this user exists with is_admin=true.
# After first login, you can remove BOOTSTRAP_ADMIN_PASSWORD (admin flag persists).
# To rotate password later, set BOOTSTRAP_ADMIN_RESET_PASSWORD=1 along with new password.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
# Role: owner | manager | agent | viewer
BOOTSTRAP_ADMIN_ROLE=owner
# Set to 1 to force password reset on next boot (then unset)
# BOOTSTRAP_ADMIN_RESET_PASSWORD=1

# ─── Admin bootstrap ───
# Comma-separated list of emails to auto-promote to admin on every boot.
# Example: ADMIN_EMAIL=btc.dhirendra@gmail.com,ops@flightdojo.it.com
ADMIN_EMAIL=

# Optional: if set AND an ADMIN_EMAIL doesn't exist as a user, that user is
# created automatically with this password on boot. Existing users are NOT
# overwritten — this only fills the gap for first-time setup.
# Must be 8+ characters. Once you're logged in, change it via Settings or
# remove from .env (the user record persists).
ADMIN_PASSWORD=
