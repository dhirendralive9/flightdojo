# ─── Duffel API ───
# Get your token at https://app.duffel.com/ → Developers → Access Tokens
DUFFEL_ACCESS_TOKEN=duffel_test_REPLACE_ME

# ─── Cloudflare Turnstile ───
# Defaults are Cloudflare's dummy "always pass" keys for development.
TURNSTILE_SITEKEY=1x00000000000000000000AA
TURNSTILE_SECRET=1x0000000000000000000000000000000AA

# ─── Stripe ───
# Get your sandbox/test keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
# Get this when you set up the webhook: https://dashboard.stripe.com/test/webhooks
# For local dev with `stripe listen`, paste the signing secret it shows you.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ─── ProxyCheck.io v3 (IP risk gate before payment) ───
# Get a free API key (1,000 lookups/day) at https://proxycheck.io/dashboard
# Without a key, the booking flow runs in PERMISSIVE mode (all IPs allowed).
PROXYCHECK_API_KEY=

# ─── MongoDB ───
# Local: mongodb://localhost:27017/flightdojo
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/flightdojo
MONGODB_URI=mongodb://localhost:27017/flightdojo

# ─── SMTP (Nodemailer) ───
# For development, sign up for free at https://mailtrap.io and grab the SMTP credentials
# from any inbox. They'll catch all outgoing email so you can preview without sending.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=REPLACE_ME
SMTP_PASS=REPLACE_ME
SMTP_FROM="FlightDojo <noreply@flightdojo.it.com>"

# ─── Airport database ───
# Set to 1 to fetch the full ~10,000-airport dataset from Travelpayouts on startup.
AIRPORTS_USE_REMOTE=0

# ─── Server config ───
PORT=3000
NODE_ENV=development
# Public base URL — used in Stripe success/cancel URLs and email links
BASE_URL=http://localhost:3000

# ─── Affiliate add-on cards ───
# Sign up at each provider, get your affiliate URL, paste below.
# Leave blank to hide the card.
#
# eSIM — Airalo Partners: https://www.airalo.com/partners
AIRALO_AFFILIATE_URL=
# Airport lounges — Priority Pass / LoungeBuddy / DragonPass / Plaza Premium
LOUNGES_AFFILIATE_URL=
# Hotels — Booking.com Partners: https://www.booking.com/affiliate
HOTELS_AFFILIATE_URL=
# Airport transfers — GetTransfer / Welcome Pickups / Booking.com Cars
TRANSFERS_AFFILIATE_URL=
# Travel insurance — XCover (Cover Genius) / HeyMondo / etc.
INSURANCE_AFFILIATE_URL=

# ─── Top ribbon (phone + contact link above main nav) ───
# Set RIBBON_ENABLED=false to hide it entirely.
RIBBON_ENABLED=true
# What's shown to the user (formatted nicely with spaces/parens)
SUPPORT_PHONE_DISPLAY=+1 (888) 555-0199
# What's used in the tel: link (digits only, with leading +)
SUPPORT_PHONE_TEL=+18885550199
# Optional tagline shown on the left side of the ribbon (hidden on mobile)
RIBBON_MESSAGE=Need help booking? Speak with a travel specialist.
